# ─── Memster Environment Variables ───
# Copy this file to .env, then uncomment and fill in your values.
# Never commit .env to version control.

# ─── Database ───
# Override SQLite path (default: ~/memster/memster_unified.db)
# MEMSTER_DB_PATH=~/memster/memster_unified.db

# ─── PostgreSQL (optional, when using PG backend) ───
# MEMSTER_PG_HOST=localhost
# MEMSTER_PG_PORT=5432
# MEMSTER_PG_DB=memster
# MEMSTER_PG_USER=memster_user
# MEMSTER_PG_PASSWORD=change_me

# ─── MCP Server ───
# PYTHONUNBUFFERED=1
