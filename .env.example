# Memster Environment Variables
# Copy this file to .env and adjust as needed.

# Embedding backend: "local" (default, CPU-friendly) or "nim" (for NVIDIA NIM API)
# ── FOR PERSONAL NIM SETUP ──
# Uncomment the line below and comment out EMBEDDING_BACKEND=local:
# EMBEDDING_BACKEND=nim
# NVIDIA_API_KEY=your-n...here
# ── END NIM SETUP ──

# Default: local (works out of the box, zero API keys)
EMBEDDING_BACKEND=local

# Local embedding model (used when EMBEDDING_BACKEND=local)
# Options: BAAI/bge-small-en-v1.5 (384-dim, fast), all-mpnet-base-v2 (768-dim, better recall)
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# NVIDIA NIM / OpenRouter API key (only required if EMBEDDING_BACKEND=nim)
# The endpoint uses OpenRouter: https://openrouter.ai/api/v1/embeddings
# Model: nvidia/llama-nemotron-embed-vl-1b-v2 (2048-dim)
NVIDIA_API_KEY=
OPENROUTER_API_KEY=

# Retrieval signal weights (tuned for LongMemEval)
WEIGHT_SEM=1.5
WEIGHT_BM25=1.0
WEIGHT_ENT=5.0
WEIGHT_TEMP=1.0

# Fusion method: "weighted" or "rrf"
FUSION_METHOD=weighted

# Advanced features (off by default for speed; enable for higher recall)
USE_QUERY_EXPANSION=true
USE_TWO_STAGE_RERANKER=true
QUERY_EXPANSION_MAX_SYNONYMS=2
TWO_STAGE_RERANKER_CANDIDATES_MULTIPLIER=5

# Database connection (adjust if needed)
DATABASE_URL=postgresql://house:@/memster?host=/run/postgresql&port=5433