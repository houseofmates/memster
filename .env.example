# ─── Memster Environment Variables ───
# Copy this file to .env, then uncomment and fill in your values.
# Never commit .env to version control.

# ─── Database (PostgreSQL required) ───
# PostgreSQL connection URL — memster now requires PostgreSQL (SQLite is no longer supported)
DATABASE_URL=postgresql://memster:password@localhost:5432/memster

# ─── MCP Server ───
# Pieces MCP bridge URL (default: localhost:39310)
# PIECES_MCP_URL=http://localhost:39310/model_context_protocol/2025-03-26/mcp

# ─── NVIDIA NIM Embeddings (optional) ───
# NVIDIA_API_KEY=your_api_key_here

# ─── Python ───
# PYTHONUNBUFFERED=1